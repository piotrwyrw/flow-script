let arr = ["Lorem", "Ipsum", "Dolor", 123, 54, "Sit", fn(){}];

arr = arr + "Amet";

fn forEach(arr, f) {
    for e in arr {
        f(e);
    };
};

forEach(arr, fn(e) {
    if e is string {
        print("String: " + e);
    } else if e is number {
        print("Number: " + e);
    } else {
        print("Unknown type.");
    };
});